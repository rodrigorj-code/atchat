{
    "name": "dev-connect-ai-wa",
    "version": "1.0",
    "description": "DevConnectAI",
    "main": "server.js",
    "scripts": {
        "start": "pm2 start src/server.js --name dev-connect-ai-wa",
        "dev": "nodemon",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint:check": "eslint .",
        "lint:fix": "eslint --fix .",
        "test": "mocha tests/*.test.js --exit",
        "configure-husky": "npx husky install && npx husky add .husky/pre-commit \"npx --no-install lint-staged\""
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{js,jsx}": [
            "prettier --write",
            "git add"
        ],
        "*.{html,css,less,ejs}": [
            "prettier --write",
            "git add"
        ]
    },
    "repository": "",
    "author": "dev-connect-ai-wa",
    "license": "MIT",
    "dependencies": {
        "@adiwajshing/keyed-db": "^0.2.4",
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@sentry/node": "^8.40.0",
        "@whiskeysockets/baileys": "https://github.com/andrew890074/Baileys",
        "axios": "^1.1.3",
        "chalk": "^4.1.2",
        "cli-table3": "^0.6.5",
        "dotenv": "^16.0.3",
        "ejs": "^3.1.7",
        "express": "^4.18.2",
        "express-exception-handler": "^1.3.23",
        "figlet": "^1.8.0",
        "i": "^0.3.7",
        "link-preview-js": "^3.0.0",
        "multer": "^1.4.5-lts.1",
        "node-cache": "^5.1.2",
        "node-cron": "^3.0.3",
        "node-mime-types": "^1.1.0",
        "npm": "^10.6.0",
        "or": "^0.2.0",
        "pino": "^8.7.0",
        "qrcode": "^1.5.1",
        "sharp": "^0.32.2",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "eslint": "^8.28.0",
        "eslint-config-prettier": "^8.5.0",
        "husky": "^8.0.2",
        "lint-staged": "^13.0.4",
        "mocha": "^10.1.0",
        "nodemon": "^2.0.20",
        "prettier": "^2.8.0",
        "supertest": "^6.3.1"
    }
}
