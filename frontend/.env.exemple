# URL completa do Node (opcional). Se vazio, no browser usa:
# mesmo host + REACT_APP_BACKEND_PORT (padrão 8080).
# Em produção com Nginx só na porta 80 servindo o SPA, defina explicitamente a URL do API Node
# (ex.: http://SEU_IP:8080) ou configure proxy no Nginx para /system-settings, /auth, /companies, etc.
# Sem isso, POST pode ir para o host :80 e retornar 405 Not Allowed.
# REACT_APP_BACKEND_URL=http://127.0.0.1:8080
REACT_APP_BACKEND_PORT=8080
REACT_APP_HOURS_CLOSE_TICKETS_AUTO=24
