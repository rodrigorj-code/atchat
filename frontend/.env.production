# Build de produção: se REACT_APP_BACKEND_URL estiver vazio, o app usa automaticamente
# http(s)://<mesmo-host-do-navegador>:REACT_APP_BACKEND_PORT (evita HTML do React no lugar da API).
#
# Descomente e ajuste só se a API estiver em outro domínio/porta fixa:
# REACT_APP_BACKEND_URL=http://127.0.0.1:8080

REACT_APP_BACKEND_PORT=8080
