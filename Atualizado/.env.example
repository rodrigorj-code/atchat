# DevConnectAI - Variáveis de ambiente
# Copie para .env e preencha os valores.

# Porta do servidor (padrão: 9898)
PORT=9898

# URL base da aplicação (ex: http://localhost:9898 ou https://seu-dominio.com)
APP_URL=http://localhost:9898

# Token para proteger as rotas da API (header: Authorization ou Bearer)
# Se vazio e protectRoutes=true, as rotas podem falhar. Use um token forte.
TOKEN_ADMIN_API=seu-token-secreto-aqui

# Redis (obrigatório para filas de mensagens)
REDIS_URI=redis://127.0.0.1:6379

# Opcional: MongoDB para persistência
# MONGODB_ENABLED=false
# MONGODB_URL=mongodb://127.0.0.1:27017/WhatsAppInstance

# Opcional: Webhook para receber eventos
# WEBHOOK_ENABLED=false
# WEBHOOK_URL=
# WEBHOOK_BASE64=false
# WEBHOOK_ALLOWED_EVENTS=all

# Opcional: marcar mensagens como lidas
# MARK_MESSAGES_READ=false

# Opcional: ignorar grupos (true/false)
# IGNORE_GROUPS=

# Opcional: tentativas máximas de QR
# INSTANCE_MAX_RETRY_QR=2
